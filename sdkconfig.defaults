# CPU
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_FREERTOS_HZ=100

# Compiler
CONFIG_COMPILER_OPTIMIZATION_PERF=y
CONFIG_COMPILER_OPTIMIZATION_ASSERTIONS_SILENT=y

# Cache
CONFIG_ESP32S3_INSTRUCTION_CACHE_32KB=y
CONFIG_ESP32S3_DATA_CACHE_32KB=y

# WiFi buffers (reduced for SRAM budget)
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=4
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=8
CONFIG_ESP_WIFI_STATIC_TX_BUFFER=y
CONFIG_ESP_WIFI_TX_BUFFER_TYPE=0
CONFIG_ESP_WIFI_STATIC_TX_BUFFER_NUM=4
CONFIG_ESP_WIFI_RX_BA_WIN=4

# LwIP (trimmed)
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=5840
CONFIG_LWIP_TCP_WND_DEFAULT=5840
CONFIG_LWIP_TCP_RECVMBOX_SIZE=6
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=16
# TA-301's "8 is enough" missed browser HTTP/1.1 keepalive — dashboard tab
# holds ~3 sockets, plus stratum + listener → exhausts at the original 8.
# 12 covers: httpd + 4 SSE clients + stratum TCP + mDNS UDP + NTP UDP +
# outbound TLS (update check) with headroom. Wroom32 saw "Failed to create
# socket" at 8/10 with all these in flight. ~360 B per slot.
CONFIG_LWIP_MAX_SOCKETS=12
# Reduce FIN_WAIT_2 residency from 20s default to 2s — pairs with the bb_log
# sse_task disconnect-detect fix in breadboard (BB #241) for the companion
# CLOSE_WAIT-side reduction. Together cuts per-disconnect socket residency
# from ~25s to ~2.5s.
CONFIG_LWIP_TCP_FIN_WAIT_TIMEOUT=2000
# bb_http reserves N sockets for non-httpd usage. Restored to BB default 3:
# the previous reserve=1 starved stratum + transient outbound (DNS lookups,
# OTA pull) under dashboard load — reproduced as bitaxe-650 panic during
# concurrent /api/* fan-out (TA-385). mDNS uses a separate MEMP_NUM_UDP_PCB
# pool, but TCP stratum reconnects + DNS still share the lwip socket pool.
# Bumped 3->5: held-SSE + concurrent /api/* exhausted the 12-socket pool and
# starved MQTT/stratum (write-timeout -> reconnect churn -> pool-offline).
# Heap-neutral re-split of the existing pool: httpd capped at 7, 5 reserved for
# MQTT/stratum/DNS so web load can't drop the miner's own connections.
CONFIG_BB_HTTP_LWIP_RESERVE=5

# NVS
CONFIG_NVS_ENCRYPTION=n

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Partition table (custom OTA layout)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# OTA rollback
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# Panic coredump (writes ELF to dedicated coredump partition; bb_diag_panic decodes on next boot)
CONFIG_BB_DIAG_PANIC_COREDUMP=y
CONFIG_ESP_COREDUMP_ENABLE_TO_FLASH=y
CONFIG_ESP_COREDUMP_DATA_FORMAT_ELF=y
CONFIG_ESP_COREDUMP_CHECKSUM_CRC32=y

# FreeRTOS trace facility (~1KB RAM; enables uxTaskGetSystemState for /api/diag/tasks)
CONFIG_FREERTOS_USE_TRACE_FACILITY=y

# Watchdog
# 60 s timeout (Kconfig range cap) absorbs long stalls during pull-OTA on bitaxe
# (TLS handshake + mbedTLS SHA on Core 1, bb_log writer TX backpressure on
# Core 0). Diagnose the starving task properly later; for now this prevents the
# rollback storm.
CONFIG_ESP_TASK_WDT_EN=y
CONFIG_ESP_TASK_WDT_TIMEOUT_S=60
CONFIG_ESP_TASK_WDT_PANIC=y
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=y
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=n

# Panic — give USB CDC TX FIFO time to flush panic dump before reset
CONFIG_ESP_SYSTEM_PANIC_REBOOT_DELAY_SECONDS=3

# FreeRTOS
CONFIG_FREERTOS_UNICORE=n

# mDNS
CONFIG_MDNS_TASK_PRIORITY=3
# We publish 5 TXT keys before mDNS starts (worker, board, version, state,
# and update_check's initial update=unknown). The breadboard default of 4
# drops the 5th at boot ("txt pending buffer full"), advertising an
# incomplete record so knot peers see missing fields. Size for our keys.
CONFIG_BB_MDNS_TXT_PENDING_MAX=8

# Event loop task stack — default 2304 overflows with mDNS + WiFi + user callbacks
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_HEADER_FLASHSIZE_UPDATE=y

# Allow writes to protected flash regions (partition table fixup)
CONFIG_SPI_FLASH_DANGEROUS_WRITE_ALLOWED=y

# USB CDC
CONFIG_ESP_CONSOLE_USB_CDC=y

# Build cache
CONFIG_COMPILER_CCACHE_ENABLE=y

# Flash size reduction — disable unused components
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_CMN=y
CONFIG_UNITY_ENABLE=n
CONFIG_MQTT_USING_ESP=n

# WiFi Enterprise (802.1X/EAP) — not used, WPA2-PSK only
CONFIG_ESP_WIFI_ENTERPRISE_SUPPORT=n

# mbedTLS dynamic-buffer mode: defer the 16 KB SSL_IN_CONTENT_LEN allocation to
# handshake time instead of permanent reservation. Frees ~16 KB at rest on every
# board; only used during OTA pull and update-check.
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
# Free the parsed CA cert bundle + tls config immediately after the handshake
# completes. Each fetch recovers ~8–12 KB that would otherwise stay live until
# esp_http_client_cleanup. Important on bitaxe-650 where heap_largest_free_block
# was dropping below the 4.7 KB mbedTLS record-buffer alloc threshold.
CONFIG_MBEDTLS_DYNAMIC_FREE_CONFIG_DATA=y
CONFIG_MBEDTLS_DYNAMIC_FREE_CA_CERT=y

# WiFi management short buffer pool: STA-only deployment doesn't need the IDF
# default of 32 (sized for SoftAP serving multiple stations). 8 covers WPA3-SAE
# four-way handshake + beacon processing with comfortable margin.
CONFIG_ESP_WIFI_MGMT_SBUF_NUM=8

# Unused mbedTLS features
CONFIG_MBEDTLS_ARIA_C=n
CONFIG_MBEDTLS_PKCS7_C=n
CONFIG_MBEDTLS_SSL_RENEGOTIATION=n
CONFIG_MBEDTLS_SSL_KEEP_PEER_CERTIFICATE=n

# mbedTLS record sizes paired with bb_ota_pull partial_http_download (4 KB GETs).
# Dropped 16 KB->8 KB->4 KB to shrink the peak mbedtls IN-buffer alloc (~5 KB) so the
# OTA-pull/update-check TLS handshake fits the fragmented internal heap on no-PSRAM
# boards (esp32-wroom32, tdongle-s3) even with the always-on telemetry ring resident.
# RISK: if GitHub/Fastly sends a handshake record >4 KB the handshake will fail
# (they ignore max-fragment-length) — revert to 8192 if the OTA TLS breaks.
# OUT lowered to 1 KB — we never send TLS payloads larger than HTTP request headers.
# THIS IS THE SINGLE OTA-HEAP KNOB: bb_ota's pre-flight largest-free-block guard
# auto-derives its floor from SSL_IN (= SSL_IN + ~1 KB record overhead), so tune
# SSL_IN alone — do NOT add a CONFIG_BB_OTA_PULL_MIN_HEAP_BLOCK_BYTES override
# (bb default 0 = auto-derive). Lowering SSL_IN moves the guard down with it,
# which is what lets the heap-tight no-PSRAM s2 (largest ~7.7 KB) clear the floor.
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=4096
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=1024

# /api/events SSE client cap. Restored to BB default 2: cap=4 reserved ~27KB
# of heap (4×4KB task stack + 4×~2.7KB queue) on ~100KB-free bitaxe-650,
# contributing to dashboard-load OOM panics (TA-385). The persistent
# update-badge subscription + a single open dashboard fit in 2 slots; the
# ~15s stale-client reap window covers tab-reload churn. Queue depth stays
# at BB default (8).
CONFIG_BB_EVENT_ROUTES_MAX_CLIENTS=2

# link-health: adaptive telemetry backoff on weak RSSI (bb_net_health)
CONFIG_BB_PUB_ADAPTIVE_BACKOFF=y
CONFIG_BB_PUB_ADAPTIVE_RSSI_THRESH=-75
CONFIG_BB_PUB_ADAPTIVE_SLOW_MS=30000
CONFIG_BB_PUB_ADAPTIVE_SAMPLES=3

# heap reclaim (no-PSRAM fragmentation) — see heap audit
# (esp-mqtt outbox is a dynamic list, empty under QoS0 — no fixed-size knob to tune)
CONFIG_BB_EVENT_ROUTES_RING_CAPACITY=8
CONFIG_BB_EVENT_ROUTES_RING_MAX_ENTRY=128
CONFIG_BB_LOG_STREAM_BUF_BYTES=3072
CONFIG_BB_LOG_STREAM_WRITER_QUEUE_LEN=8

# BB sensors route (B1-269, v0.62.0+): /api/sensors serves fan/power/thermal/miner
# as a consolidated endpoint. CONFIG_BB_SENSORS_AUTOREGISTER defaults y — no override needed.
# The old /api/power, /api/fan, /api/thermal routes are deleted; their bb_*_init are no-op stubs.

# BB autofan: BB fully owns fan duty and autofan PID when enabled.
# TM wires cfg from NVS, feeds VR aux temp, and registers persist callback.
CONFIG_BB_FAN_AUTOFAN=y

# Telemetry transport: MQTT plaintext only (release). The HTTP sink is
# validation-only; disabling its autoregister drops the sink + the
# /api/telemetry "http" section so the fleet ships mqtt-only. Sink-TLS gates
# stay at the breadboard opt-in default (n). The -tls validation envs re-enable
# the http sink via sdkconfig/tls-server.
CONFIG_BB_SINK_HTTP_TELEMETRY_AUTOREGISTER=n

# Store-and-forward: ALWAYS-ON ring (uniform queue) fleet-wide. In always-on mode
# EVERY active source enqueues into the ring each tick and the ring is drained only
# after the whole source loop -- so MAX_ENTRIES must be >= the number of sources that
# enqueue in one tick, or the first-enqueued sources are evicted before the drain
# (silent live-data loss; buffer_dropped climbs in steady state). No-PSRAM boards have
# ~5 active sources/tick (fan/power/thermal skip with no HAL) so 8 holds a full tick
# plus a little outage headroom. PSRAM boards (bitaxe) have ~8 active sources/tick (all
# HALs present) and override to 16 in SPIRAM (see sdkconfig/bitaxe-*). Payload 512 B
# fits the oversized ~535 B "info" entry. Ring = (192+1+512)*8 ~= 5.6 KB internal.
CONFIG_BB_PUB_BUFFER_ENABLE=y
CONFIG_BB_PUB_BUFFER_ALWAYS=y
CONFIG_BB_PUB_BUFFER_MAX_PAYLOAD_BYTES=512
CONFIG_BB_PUB_BUFFER_MAX_ENTRIES=8
# bb_pub source cap: 7 breadboard auto-registered sources + mining (this file) = 8;
# raised to 14 for B1-352 (mining_rates + pool + sensors_miner) + headroom.
CONFIG_BB_PUB_MAX_SOURCES=14

# B1-352 event-topic caps: 14 topics non-ASIC / 15 ASIC attach to bb_event_routes at
# runtime (block.found + pool.notify + health.alerts + net.health + 7 bb_sink_event
# periodic topics + update.available + diag.boot + health.stack; +sensors_miner on ASIC).
# Default BB_EVENT_ROUTES_MAX_TOPICS=8 and BB_EVENT_MAX_TOPICS=8 were already saturated
# by pre-existing topics, causing bb_sink_event_register_topic to return NO_SPACE and the
# new periodic SSE topics to silently not appear on /api/diag/events (HW-soak confirmed).
# BB_SINK_EVENT_MAX_TOPICS defaults to 16 — already covers our 8 periodic topics; no change.
# Set to 20 (not 16) for headroom: 15 ASIC topics would sit 1 slot from the same silent
# NO_SPACE overflow that caused this bug, so 5 slots of slack guard the next added SSE topic.
# BSS delta from the default 8: ~216 B/topic (routes table + client subs + event registry +
# sub pool) x 12 = ~2.6 KB total; acceptable on all no-PSRAM boards (ring storage is
# heap/SPIRAM-preferred, unchanged). No per-board ring-size override required.
CONFIG_BB_EVENT_ROUTES_MAX_TOPICS=20
CONFIG_BB_EVENT_MAX_TOPICS=20

# Stack recoup (valid trim): esp-mqtt internal task 6144->5120 (worst observed
# use ~2372 B -> ~2748 B margin). Raise MQTT_TASK_STACK_SIZE back to 8192 in any
# MQTT-TLS overlay.
CONFIG_MQTT_USE_CUSTOM_CONFIG=y
CONFIG_MQTT_TASK_STACK_SIZE=5120

# B1-352: bb_pub worker raised 4096->8192. The new mining_rates/pool/sensors_miner
# sources build snapshot structs + JSON on the worker stack each tick; the 4096
# plaintext default stack-overflowed (HW-confirmed on tdongle-s3 bb_pub task).
# 8192 matches the TLS-overlay size and clears it with margin (~+4 KB heap).
CONFIG_BB_PUB_WORKER_STACK=8192

# TA-432: dual-core bb_pub/esp-mqtt race — pin both tasks to core 0 (network
# core) so they serialize. Mining runs on core 1 (see Architecture in CLAUDE.md).
# Single-core boards (s2/c3) ignore both settings harmlessly.
CONFIG_BB_PUB_WORKER_CORE=0
CONFIG_MQTT_TASK_CORE_SELECTION_ENABLED=y
CONFIG_MQTT_USE_CORE_0=y

# Prometheus metric namespace for GET /api/telemetry/metrics: taipanminer_<source>_<field>
# instead of breadboard's default "bb" prefix (compile-time, no runtime call).
CONFIG_BB_METRICS_PREFIX="taipanminer"
