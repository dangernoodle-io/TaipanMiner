# Copy this file to .clangd and uncomment ONE CompilationDatabase line
# matching the PlatformIO env you're actively developing. .clangd is
# gitignored — each developer picks their own variant.
#
# Run `make compile-db` once first (or `pio run -t compiledb -e <env>`
# for a single board) so the compile DB exists.
#
# When adding a new board to platformio.ini, add a matching commented
# line below so developers working on that board get an LSP template
# out of the box. Also add a `pio run -t compiledb -e <env>` line to
# the `compile-db` target in the Makefile.

CompileFlags:
  # CompilationDatabase: .pio/build/bitaxe-601
  # CompilationDatabase: .pio/build/bitaxe-403
  # CompilationDatabase: .pio/build/tdongle-s3
  Remove:
    - -mlongcalls
    - -mtext-section-literals
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    - -fno-shrink-wrap
  Add:
    - -Wno-unknown-warning-option
    - -Wno-unknown-attributes
