#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
VENV="$SCRIPT_DIR/.venv"
VENV_PYTHON="$VENV/bin/python"
REQUIREMENTS="$SCRIPT_DIR/requirements.txt"
STAMP="$VENV/.requirements.sha"

_sha() { sha256sum "$1" 2>/dev/null || shasum -a 256 "$1"; }

# Ensure python3 is available
if ! command -v python3 &>/dev/null; then
    echo "[fleet] Error: python3 not found. Install Python 3.11+ and retry." >&2
    exit 1
fi

# Bootstrap venv on first run
if [[ ! -x "$VENV_PYTHON" ]]; then
    echo "[fleet] Creating venv (first run needs network for pip install)..." >&2
    python3 -m venv "$VENV"
    echo "[fleet] Installing dependencies from requirements.txt..." >&2
    "$VENV/bin/pip" install -q -r "$REQUIREMENTS"
    _sha "$REQUIREMENTS" > "$STAMP"
fi

# Re-install if requirements.txt changed since last successful install
if [[ -f "$STAMP" ]]; then
    CURRENT="$(_sha "$REQUIREMENTS")"
    STORED="$(cat "$STAMP")"
    if [[ "$CURRENT" != "$STORED" ]]; then
        echo "[fleet] requirements.txt changed — re-installing deps..." >&2
        "$VENV/bin/pip" install -q -r "$REQUIREMENTS"
        _sha "$REQUIREMENTS" > "$STAMP"
    fi
else
    # venv exists but no stamp — write it now
    _sha "$REQUIREMENTS" > "$STAMP"
fi

exec "$VENV_PYTHON" "$SCRIPT_DIR/fleet.py" "$@"
