managed_components/
# IDF component-manager lock: re-generated per build and stamped with the
# last-built `target:`, so it churns on every board switch. The only managed
# dep (espressif/mdns) is pinned by its manifest range (~1.11.0 in breadboard's
# bb_mdns), which is the real version constraint and lets patch fixes flow in.
dependencies.lock
sdkconfig.tdongle-s3
sdkconfig.tdongle-s3-debug
sdkconfig.bitaxe-601
sdkconfig.bitaxe-601-debug
sdkconfig.bitaxe-403
sdkconfig.bitaxe-403-debug
sdkconfig.bitaxe-650
sdkconfig.bitaxe-650-debug
sdkconfig.esp32-wroom32
sdkconfig.esp32-wroom32-debug
sdkconfig.esp32-s2-mini
sdkconfig.esp32-s2-mini-debug
sdkconfig.esp32-c3-supermini
sdkconfig.esp32-c3-supermini-debug
sdkconfig.esp32-wroom32-cyd
sdkconfig.esp32-wroom32-cyd-debug
sdkconfig.esp32-wroom32-tls
sdkconfig.esp32-s2-mini-tls
sdkconfig.esp32-c3-supermini-tls
sdkconfig.tdongle-s3-tls
sdkconfig.bitaxe-601-tls
