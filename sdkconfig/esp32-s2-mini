# ESP32-S2 Mini configuration — delta from sdkconfig.defaults + sdkconfig/single-core.
# Shared single-core settings (FREERTOS_UNICORE, WDT_CPU1, YIELD_MASK, WIFI_IRAM, MDNS) are in sdkconfig/single-core.
CONFIG_IDF_TARGET="esp32s2"
CONFIG_IDF_TARGET_ESP32S2=y
CONFIG_ESP32S3_INSTRUCTION_CACHE_32KB=n
CONFIG_ESP32S3_DATA_CACHE_32KB=n

# WiFi power-save: keep NONE on the S2 specifically. The fleet default is now
# MIN_MODEM (breadboard Kconfig default); the fleet-wide PS_NONE was reverted in
# TA-438 because it raised tdongle-s3 die temps with no stratum benefit. The S2
# still needs PS_NONE: modem-sleep starves the WiFi task under the single-core
# scheduler, causing idle disconnects — a single-core reason, distinct from the
# (separately-resolved) mesh-roaming weak-signal issue.
CONFIG_BB_WIFI_PS_NONE=y

# Flash size: S2 Mini has 4MB
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=n
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_esp32_4mb.csv"

# Console: UART0 (GPIO43 TX / GPIO44 RX). The S2 ROM USB-CDC console faults in
# usb_dc_ep_write (null endpoint deref) when log output can't drain headless,
# crash-looping the board. UART0 is reliable; needs an external USB-UART adapter.
CONFIG_ESP_CONSOLE_USB_CDC=n
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_UART_NUM=0

# Hot-loop pinning not beneficial on single-core; stack placement is faster here.
# See mining Kconfig.
CONFIG_MINING_PIN_HOTLOOP_DATA=n

# Lever 1: move TX buffers to heap (avoids static alloc at esp_wifi_init)
# ESP_WIFI_STATIC_TX_BUFFER / ESP_WIFI_DYNAMIC_TX_BUFFER are a choice block;
# select Dynamic by enabling it (disables Static implicitly).
# NUM kept modest: each dynamic TX buffer is ~1.6KB of heap; 8 is plenty for a
# miner and leaves contiguous heap for the 8KB stratum task stack + TLS. (16
# fragmented the heap so badly the stratum task couldn't allocate its stack.)
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER=y
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=8
# Lever 2: reduce static RX buffers (min=3 for RX_BA_WIN=6)
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=3
# Lever 3: reduce mDNS event pool (EVT_POOL_SIZE governs queue depth now)
CONFIG_BB_MDNS_EVT_POOL_SIZE=4

# mDNS is kept on the S2 — main.c inits it on the runtime mdns_en flag regardless of AUTOREGISTER; it runs fine here (knot peer discovery works).

# Mining-mode web dashboard: OFF on the S2. Validated on-device that serving the
# SPA drives heap_minimum_ever to ~2.4KB (TCP send-window saturation, a fixed
# ~9KB cost independent of bundle size) — one concurrent request from OOM on
# this no-PSRAM part. /api/* stays registered (headless observability). C3 +
# dual-core boards keep the UI (default y).
CONFIG_WEBUI_MINING_UI=n

# OTA strategy = boot-mode: STRATEGY_BOOT + progress/status HTTP + apply-fallback
# are in sdkconfig/ota-boot (shared with all non-PSRAM boards). STRATEGY_BOOT
# also implicitly flips UPDATE_CHECK_AUTOREGISTER and PULL_AUTOREGISTER off via
# Kconfig selects — no need to pin them here.
# OTA push receive buffer: v0.41.2 makes this a Kconfig (default 1024).
# 1024 stalled the push on the single-core S2 (task_wdt); 4096 completes.
CONFIG_BB_OTA_PUSH_RECV_BUF_SIZE=4096

# bb_event MUST auto-init: app_main registers the "block.found" SSE topic
# (bb_event_topic_register), which needs bb_event_init to have run. These are
# default-y in Kconfig and =y on every other board, but the S2's gitignored
# generated sdkconfig had them stale-"not set", so bb_event never initialized and
# block.found aborted app_main into a crash-loop. Pin them so a stale generated
# config can't regress it. (main.c also degrades gracefully if they're ever off.)
CONFIG_BB_EVENT_AUTOREGISTER=y
CONFIG_BB_EVENT_ROUTES_AUTOREGISTER=y

# Heap budget: S2 has no PSRAM, so runtime heap is tight. Shrink the log-stream
# ring (lazy-allocated, default 6KB) to free heap for stratum + httpd/SPA.
CONFIG_BB_LOG_STREAM_BUF_BYTES=2048

# Headless observability: no USB-CDC console in run mode (UART0 only, needs an
# external adapter). Enable the bb_log UDP sink so OTA-only boot mode
# (bb_ota_boot) can broadcast its live pull trace; bb_ota_boot enables it during
# the pull. Listen with: nc -ul 9999.
CONFIG_BB_LOG_UDP_SINK=y

# More heap reclaim so the 8KB mining-task stack can allocate (stratum took the
# first 8KB block; the miner needs a second). Stratum is low-bandwidth, so fewer
# WiFi RX buffers + smaller lwIP TCP windows are fine here.
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=4
# RX_BA_WIN must be <= DYNAMIC_RX_BUFFER_NUM; lower the block-ack window to match
# (reduces RX aggregation throughput, irrelevant for low-bandwidth stratum).
CONFIG_ESP_WIFI_RX_BA_WIN=4
# aligned to no-psram fragment (2920); previous 2880 was an unnecessary deviation
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=2920
CONFIG_LWIP_TCP_WND_DEFAULT=2920

# S2 heap reclaim — HWM-measured, safe to trim on the heap-critical S2:
# bb_event_routes replay ring: default 16, sized for rare block.found events; 4 is sufficient.
CONFIG_BB_EVENT_ROUTES_RING_CAPACITY=4
# SSE replay ring entry size: S2 is heap-tightest; 192 fits its ~146B info/pool payloads while
# saving ring heap vs the fleet default 256 (the S2 has no 240B sensors_miner, so 256 not needed).
CONFIG_BB_EVENT_ROUTES_RING_MAX_ENTRY=192
# bb_event dispatcher queue depth: default 16; 8 is sufficient for low-rate mining events.
CONFIG_BB_EVENT_QUEUE_DEPTH=8

# B1-352 heap: the new SSE telemetry sources/topics pushed the S2 over its budget
# (OOM on boot, .107). BUFFER_ALWAYS=n is now the fleet-wide default (sdkconfig.defaults).
# S2-only override: drop MAX_ENTRIES 8→4 to further cap heap during broker-outage episodes.
# Together: 0 KB standing cost (was 5.6 KB) + max ~2.8 KB transient during broker outage.
CONFIG_BB_PUB_BUFFER_MAX_ENTRIES=4

# OTA update-check pre-flight (B1-280 follow-on): the S2 is too heap-tight to run a
# steady-state GitHub TLS handshake — ~20 KB transient against ~25 KB free OOM-panics
# mid-check even with the MQTT pause hook and the ring disabled. It clears bb_ota's
# contiguous-block guard but not the *total-free* budget, so set the total-free floor
# above what it can offer: POST /api/update/check then returns check_on_apply cleanly
# and the manifest check runs at apply time (boot-OTA, full early-boot heap). 30720 =
# GitHub-TLS transient + margin (it panicked at ~25.5 KB free). Buffering + sockets
# stay at the fleet default — the check no longer runs in steady state, so the ~2.8 KB
# always-on ring is affordable and store-and-forward replay is kept.
CONFIG_BB_OTA_PULL_MIN_FREE_HEAP_BYTES=30720

# B1-352 opt-in telemetry (breadboard v0.70.0): attach only hardware this board has.
CONFIG_BB_PUB_THERMAL_AUTO_ATTACH=y

# bb_log_event SSE queue: default 48 entries × 192 B ≈ 9 KB heap — far too large for the S2 budget.
# 8 entries ≈ 1.5 KB; drops are observable via bb_log_event_dropped(). Keep AUTO_ATTACH=y for headless
# observability (no USB-CDC console; this is the only live log path in run mode).
CONFIG_BB_LOG_EVENT_QUEUE_LEN=8

# TA-505 serialize caps: load-bearing override — sdkconfig.defaults sets 1024 for PSRAM/bitaxe;
# bb #616 Kconfig derives 512 on non-SPIRAM axis but loses to the explicit sdkconfig.defaults
# fragment (higher precedence). S2 doesn't chain no-psram, so this fragment is the override.
CONFIG_BB_PUB_TELEM_SERIALIZE_MAX=512
CONFIG_BB_PUB_TELEM_SNAP_MAX=512

# mDNS batch ring depth removed: bb #616 derives depth=3 from the SPIRAM axis (not in
# sdkconfig.defaults, so the Kconfig default wins and no fragment line is needed).
