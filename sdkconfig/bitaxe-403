# Bitaxe 403 — delta from sdkconfig.defaults
# TA-318: vcore-collapse watchdog (default n in Kconfig; ASIC boards opt in here).
CONFIG_TM_VCORE_WATCHDOG=y
CONFIG_UART_ISR_IN_IRAM=y
CONFIG_VFS_SELECT_IN_RAM=y
CONFIG_BB_DISPLAY_SSD1306_HEIGHT=32

# PSRAM — ESP32-S3-WROOM-1-N16R8 (8MB octal).
# Unlocks ~8MB heap; moves WiFi/LWIP and mbedTLS large buffers off internal SRAM
# so OTA pull HTTPS handshakes no longer fragmentation-fail at high uptime.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y
# Pin WiFi block-ack window to match our tight RX buffer counts (8 dynamic, 4 static).
# Enabling SPIRAM otherwise lets ESP-IDF auto-bump BA_WIN past those limits and the
# build hard-errors. Stays compatible with sdkconfig.defaults' WiFi buffer settings.
CONFIG_ESP_WIFI_RX_BA_WIN=6

# Telemetry store-and-forward ring: PSRAM override of the no-PSRAM default (8).
# Bitaxe has ~8 active bb_pub sources/tick (info/wifi/fan/power/thermal/health/rtos +
# mining) -- in always-on mode the ring must hold a full tick or the first-enqueued
# sources (wifi/thermal/rtos/power) are evicted before the drain. 16 = one tick + outage
# headroom; lives in SPIRAM so the internal-heap cost is nil.
CONFIG_BB_PUB_BUFFER_MAX_ENTRIES=16

# B1-352 opt-in telemetry (breadboard v0.70.0): attach only hardware this board has.
CONFIG_BB_PUB_FAN_AUTO_ATTACH=y
CONFIG_BB_PUB_POWER_AUTO_ATTACH=y
CONFIG_BB_PUB_THERMAL_AUTO_ATTACH=y
CONFIG_BB_DISPLAY_INFO_AUTO_ATTACH=y
