# Bitaxe 601 — delta from sdkconfig.defaults
CONFIG_UART_ISR_IN_IRAM=y
CONFIG_VFS_SELECT_IN_RAM=y
CONFIG_BB_DISPLAY_SSD1306_HEIGHT=32

# PSRAM — ESP32-S3-WROOM-1-N16R8 (8MB octal).
# Unlocks ~8MB heap; moves WiFi/LWIP and mbedTLS large buffers off internal SRAM
# so OTA pull HTTPS handshakes no longer fragmentation-fail at high uptime.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y
# Pin WiFi block-ack window to match our tight RX buffer counts (8 dynamic, 4 static).
# Enabling SPIRAM otherwise lets ESP-IDF auto-bump BA_WIN past those limits and the
# build hard-errors. Stays compatible with sdkconfig.defaults' WiFi buffer settings.
CONFIG_ESP_WIFI_RX_BA_WIN=6
