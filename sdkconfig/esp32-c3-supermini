# ESP32-C3 SuperMini configuration — delta from sdkconfig.defaults
CONFIG_IDF_TARGET="esp32c3"
CONFIG_IDF_TARGET_ESP32C3=y
CONFIG_ESP32S3_INSTRUCTION_CACHE_32KB=n
CONFIG_ESP32S3_DATA_CACHE_32KB=n

# Single-core: override defaults that assume dual-core
CONFIG_FREERTOS_UNICORE=y
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=n

# Flash size: C3 SuperMini has 4MB
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=n
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_esp32_4mb.csv"

# Console: USB Serial/JTAG (C3 has no USB CDC; JTAG peripheral is the CDC path)
CONFIG_ESP_CONSOLE_USB_CDC=n
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# Hot-loop pinning not beneficial on single-core; stack placement is faster here.
# See mining Kconfig.
CONFIG_MINING_PIN_HOTLOOP_DATA=n

# TA-401: yield every 8K nonces. The C3 hashrate is mask-insensitive in the
# 0x1FFF-0xFFFF range (~312 kH/s settled either way); 0x1FFF chosen for parity
# with the S2 (which strongly prefers it) and marginally tighter HTTP latency.
CONFIG_MINING_UNICORE_YIELD_MASK=0x1FFF

# Keep mbedTLS hardware AES ON. An earlier =n (software AES) override was added
# when the esp-aes per-record DMA alloc failed during OTA ("esp-aes: Failed to
# allocate memory") — but that was heap fragmentation from running the pull with
# mining un-paused. The ota-pull worker now outranks the miner (main.c) so mining
# pauses and the heap stays healthy (min ~90KB); the DMA alloc succeeds and HW AES
# cuts the ~1.4MB pull from ~225s (SW AES) to ~35s.
CONFIG_MBEDTLS_HARDWARE_AES=y

# Free DRAM for the TLS pull-OTA path. The manifest *fetch* otherwise bottoms the
# heap to ~80 bytes; moving WiFi IRAM code to flash (~15KB, cached-flash so
# negligible cost) plus shrinking the lazy log-stream ring fixes the check. The
# sustained pull *download* is kept heap-healthy by pausing mining for its
# duration (the OTA-pull worker runs above the miner — see main.c), which lets the
# TCP consumer drain WiFi RX so the buffer pool never balloons (min-heap stays
# ~90KB during a full download). No WiFi/lwIP buffer caps needed — they only
# throttled throughput. WiFi buffers untouched: the served mining UI is unaffected.
CONFIG_ESP_WIFI_IRAM_OPT=n
CONFIG_ESP_WIFI_RX_IRAM_OPT=n
CONFIG_BB_LOG_STREAM_BUF_BYTES=2048

# C3 heap reclaim — pure-margin conservative trims mirroring S2 experience
# (HWM-measured safe on the S2; the C3 is next-tightest no-PSRAM board).
# Skip bb_event ring/queue trims: the C3 serves the mining UI dashboard, which
# needs the event replay headroom (the S2 disables the UI via CONFIG_WEBUI_MINING_UI=n).
# mDNS batch size: bss batch arrays, 16→4 recovers ~12 KB; replayed next refresh.
CONFIG_BB_MDNS_BATCH_MAX=4

# OTA pull: 2 KB Range chunks (vs 4 KB default). No-PSRAM single-core in-place
# pull — halves the per-TLS-record mbedTLS alloc (~4.4 KB→~2.2 KB) so the
# download survives a heap fragmented under concurrent httpd/SSE load. See
# bb_ota_pull Kconfig.
CONFIG_BB_OTA_PULL_HTTP_CHUNK_SIZE=2048
