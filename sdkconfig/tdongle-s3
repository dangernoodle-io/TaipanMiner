# LilyGo T-Dongle S3 — delta from sdkconfig.defaults

# PSRAM — LilyGo ships T-Dongle S3 in both no-PSRAM and Plus (with PSRAM)
# variants. Quad mode + IGNORE_NOTFOUND so the same binary works on either:
# present hardware is used; absent hardware logs a warning and falls back.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_QUAD=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_IGNORE_NOTFOUND=y
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y
# Pin WiFi block-ack window to match our tight RX buffer counts (8 dynamic, 4 static).
# Enabling SPIRAM otherwise lets ESP-IDF auto-bump BA_WIN past those limits and the
# build hard-errors. Stays compatible with sdkconfig.defaults' WiFi buffer settings.
CONFIG_ESP_WIFI_RX_BA_WIN=6
