# ESP32-CYD (Elegoo 2432S028R) configuration — delta from sdkconfig.defaults
CONFIG_IDF_TARGET="esp32"
CONFIG_IDF_TARGET_ESP32=y
CONFIG_ESP32S3_INSTRUCTION_CACHE_32KB=n
CONFIG_ESP32S3_DATA_CACHE_32KB=n
CONFIG_ESP32_DEFAULT_CPU_FREQ_240=y

# Flash size: 4 MB
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=n
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_esp32_4mb.csv"

# D0 hot-loop data: stack placement measures ~1.5% faster on classic ESP32
CONFIG_MINING_PIN_HOTLOOP_DATA=n

# ILI9341 SPI display driver options
# Kconfig values: 2 = SPI2_HOST (HSPI, GPIO 13/12/14), 3 = SPI3_HOST (VSPI).
# The CYD wires the LCD to HSPI — use SPI2_HOST (Kconfig value 2).
CONFIG_BB_DISPLAY_ILI9341_SPI_HOST=2
CONFIG_BB_DISPLAY_ILI9341_PIXEL_CLK_HZ=40000000
# Backlight is active-HIGH on the CYD (BL=21, HIGH=on)
CONFIG_BB_DISPLAY_ILI9341_BL_ACTIVE_LOW=n
# This CYD's LCD MISO/SDO is not wired (write-only panel) — RDDID returns zeros.
# Skip the probe; the panel is committed at build time and writes work at 40 MHz.
CONFIG_BB_DISPLAY_ILI9341_SKIP_PROBE=y

# Full-DRAM coredump: capture all DRAM (.bss/.data/heap) so globals and the
# bb_log ring buffer survive a panic for post-mortem (espcoredump). Pairs with
# the enlarged 512 KB coredump partition in partitions_esp32_4mb_coredump.csv.
CONFIG_ESP_COREDUMP_CAPTURE_DRAM=y

# OTA pull: 2 KB Range chunks (vs 4 KB default). No-PSRAM in-place pull — halves
# the per-TLS-record mbedTLS alloc (~4.4 KB→~2.2 KB) so the download survives a
# heap fragmented under concurrent httpd/SSE load. See bb_ota_pull Kconfig.
CONFIG_BB_OTA_PULL_HTTP_CHUNK_SIZE=1024

# heap: smaller TCP window on no-PSRAM (OTA moves to boot-mode)
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=2920
CONFIG_LWIP_TCP_WND_DEFAULT=2920
